# Server port (Render sets this automatically)
PORT=3001

# Node environment
NODE_ENV=development

# LibreTranslate — supports both variable names
LIBRE_TRANSLATE_URL=https://libretranslate.com
LIBRETRANSLATE_URL=

# LibreTranslate API key (optional — required for libretranslate.com public API)
LIBRE_TRANSLATE_API_KEY=
LIBRETRANSLATE_API_KEY=

# Google Translate v2 API key (optional — unlocks Google provider)
GOOGLE_API_KEY=
TRANSLATE_API_KEY=

# MyMemory email (optional — increases free quota)
MYMEMORY_EMAIL=

# CORS — comma-separated list of allowed frontend origins
# Example: https://myuser.github.io,https://mytranslator.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Log level: error | warn | info | debug
LOG_LEVEL=info
