# NexusAI Environment Variables
# Copy this file to backend/.env and fill in your values.
# Never commit a .env file with real keys to version control.

# ── AI Fallback (optional — leave blank for offline/FAQ-only mode) ──
# Gemini API key → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI API key → https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Search Settings ──────────────────────────────────────────────────
# Minimum confidence % (0-100) required to return a FAQ answer.
# Lower = more answers returned; higher = more precise but may miss.
CONFIDENCE_THRESHOLD=40

# ── CORS (restrict in production if needed) ──────────────────────────
# CORS_ORIGINS=https://yourusername.github.io

# ── Server Settings ──────────────────────────────────────────────────
PORT=5000
DEBUG=false
