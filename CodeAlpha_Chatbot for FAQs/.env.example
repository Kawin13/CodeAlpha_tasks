# ── NexusAI Environment Variables ─────────────────────────
# Copy to .env for local development (never commit .env)

PORT=5000
DEBUG=false
CONFIDENCE_THRESHOLD=40

# CORS: comma-separated list of allowed frontend origins
# Default already includes GitHub Pages + localhost — override here if needed
CORS_ORIGINS=https://kawin13.github.io,http://localhost:5000,http://localhost:3000

# Optional AI fallbacks (leave blank to use FAQ-only mode)
GEMINI_API_KEY=
OPENAI_API_KEY=
